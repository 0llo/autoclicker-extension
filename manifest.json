{
  "manifest_version": 3,
  "name": "High Precision Auto-Clicker",
  "version": "1.0",
  "description": "Click an element exactly at a specified time with millisecond precision.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "Auto-Clicker 設定",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
