{
  "manifest_version": 3,
  "name": "High Precision Auto-Clicker",
  "version": "1.0.1",
  "description": "ミリ秒単位の即時性が求められる予約サイトなどで、指定時刻ジャストに要素を高速クリックします。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
